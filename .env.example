# =====================================================
# GPT-ERP Environment Variables
# Copy this file to .env (local) or set in Vercel dashboard
# =====================================================

# --- Database (Neon Postgres) ---
# Get from: https://console.neon.tech > Project > Connection Details
# Use the POOLED connection string (with -pooler in hostname) for serverless
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Prisma Accelerate (optional, for connection pooling in serverless)
# Get from: https://console.prisma.io
PRISMA_ACCELERATE_URL=""

# --- Auth.js (NextAuth v5) ---
# Generate: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_OPENSSL_RAND_BASE64_32"

# Vercel auto-sets this, but for local dev:
AUTH_URL="http://localhost:3000"

# --- Vercel Blob (file attachments) ---
# Get from: Vercel Dashboard > Storage > Blob > Create Store
BLOB_READ_WRITE_TOKEN="vercel_blob_xxx"

# --- App ---
NEXT_PUBLIC_APP_NAME="GPT-ERP"
NEXT_PUBLIC_APP_VERSION="0.1.0"
