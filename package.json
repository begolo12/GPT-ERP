{
  "name": "gpt-erp",
  "version": "0.1.0",
  "private": true,
  "description": "Daniswara Group ERP \u2014 multi-company, modular, enterprise-grade",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "start": "pnpm --filter web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter web db:generate",
    "db:push": "pnpm --filter web db:push",
    "db:seed": "pnpm --filter web db:seed",
    "db:studio": "pnpm --filter web db:studio"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
